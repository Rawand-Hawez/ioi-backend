# ==============================================================================
# IOI BACKEND SKELETON - ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file defines the core configuration for the high-performance Go stack.
# Copy this to .env and customize for your local development environment.
# ==============================================================================

# --- NETWORK & ACCESS CONTROL -------------------------------------------------
# The port where the PostgREST (auto-CRUD) API will be accessible.
API_PORT_REST=3000

# The port where the custom Go (Fiber) API will be accessible.
API_PORT_FIBER=8080

# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080


# --- DATABASE (POSTGRESQL 18) -------------------------------------------------
# Standard PostgreSQL connection parameters.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate-a-secure-password-here
POSTGRES_DB=app_database
POSTGRES_PORT=5432

# SSL mode for database connections. Set to 'require' or 'verify-full' in production.
POSTGRES_SSLMODE=disable


# --- POSTGREST (AUTO-CRUD API) ------------------------------------------------
# Password for the PostgREST 'authenticator' database role.
POSTGREST_PASSWORD=generate-a-secure-postgrest-password


# --- IDENTITY & AUTHENTICATION (GOTRUE) ---------------------------------------
# The port where the GoTrue auth service will be accessible.
GOTRUE_PORT=9999

# HS256 JWT Secret key (Must be at least 32 characters for security).
GOTRUE_JWT_SECRET=generate-a-32-64-character-jwt-secret-here

# GoTrue database driver (strictly postgres).
GOTRUE_DB_DRIVER=postgres

# The base URL of your frontend application for redirecting after auth events.
GOTRUE_SITE_URL=http://localhost:5173

# Set to 'false' in production to enforce email verification.
# Requires SMTP configuration in GoTrue (GOTRUE_SMTP_HOST, GOTRUE_SMTP_PORT, etc.)
GOTRUE_MAILER_AUTOCONFIRM=true


# --- OBJECT STORAGE (MINIO) ---------------------------------------------------
# MinIO S3-compatible API port.
MINIO_PORT=9000

# MinIO Web Console port.
MINIO_CONSOLE_PORT=9001

# Root administrative credentials for MinIO.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=generate-a-secure-admin-password


# --- CACHE & REALTIME STATE (DRAGONFLY) ---------------------------------------
# Dragonfly (Multi-threaded Redis replacement) port.
DRAGONFLY_PORT=6379

# Password for Dragonfly auth. Leave empty for local dev (no auth by default).
# Set to a strong password in production and configure Dragonfly with --requirepass.
DRAGONFLY_PASSWORD=

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
